<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reports & Settings Menu - ESCR DQMS</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { 
            font-family: 'Times New Roman', serif; 
            margin: 0; 
            background: linear-gradient(135deg, #b7ffd8 0%, #e1f5fe 50%, #90caf9 100%); 
            display: flex; 
            flex-direction: column; 
            min-height: 100vh;
        }
        .header { 
            display: flex; 
            align-items: center; 
            justify-content: space-between; 
            padding: 15px 30px; 
            background: white; 
            border-bottom: 1px solid #ccc; 
        }
        .logo-box { display: flex; align-items: center; gap: 10px; }
        .logo-box img { width: 65px; }
        .logo-box span { font-weight: bold; color: #1a2a4d; }
        .window-badge {
            background: #1a2a4d;
            color: white;
            padding: 8px 20px;
            border-radius: 20px;
            font-weight: bold;
        }
        .container { 
            text-align: center; 
            margin-top: 100px; 
            flex-grow: 1;
        }
        .container h2 { 
            color: #1a2a4d; 
            font-size: 36px; 
            margin-bottom: 10px;
        }
        .container p { 
            color: #555; 
            font-size: 18px; 
            margin-bottom: 40px; 
        }
        .selection-box { 
            display: flex; 
            flex-direction: column; 
            align-items: center; 
            gap: 20px; 
            margin-top: 30px;
        }
        
        .menu-btn {
            background-color: #1a2a4d;
            color: white;
            width: 350px;
            padding: 25px;
            border-radius: 15px;
            text-decoration: none;
            font-size: 24px;
            transition: 0.3s;
            box-shadow: 0 4px 6px rgba(0,0,0,0.2);
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            border: none;
            cursor: pointer;
        }

        .menu-btn:hover { 
            background-color: #111b33; 
            transform: scale(1.02); 
        }
        
        .back-link { 
            margin-top: 30px; 
            display: inline-block; 
            color: #1a2a4d; 
            font-weight: bold; 
            text-decoration: none;
            font-size: 18px;
        }
        .back-link:hover { 
            text-decoration: underline; 
        }
    </style>
</head>
<body>

    <div class="header">
        <div class="logo-box">
            <img src="/images/escr-logo.png" alt="Logo" onerror="this.src='https://via.placeholder.com/45x45?text=ESCR'">
            <span>East Systems Colleges of Rizal</span>
        </div>
        <div class="window-badge">Window <%= windowId || '1' %></div>
    </div>

    <div class="container">
        <h2>🛡️Administrative Controls</h2>
        <p>Choose which section you would like to manage:</p>

        <div class="selection-box">
            <a href="/admin-reports" class="menu-btn">
                <i class="fa fa-chart-bar"></i> View Reports
            </a>
            
            <a href="/admin-settings" class="menu-btn">
                <i class="fa fa-cog"></i> System Settings
            </a>
            
            <a href="/admin-selection" class="back-link">
                ← Back to Main Menu
            </a>
        </div>
    </div>

</body>
</html>
