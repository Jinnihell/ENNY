<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password - ESCR DQMS</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <style>
    body { 
      font-family: 'Segoe UI', sans-serif; 
      background: linear-gradient(135deg, #b7ffd8 0%, #e1f5fe 50%, #90caf9 100%); 
      display: flex; justify-content: center; align-items: center; 
      min-height: 100vh; margin: 0; padding: 20px; box-sizing: border-box;
    }
    .container { 
      background: white; 
      padding: clamp(25px, 6vw, 50px) clamp(20px, 5vw, 45px); 
      border-radius: 25px; 
      box-shadow: 0 20px 60px rgba(0,0,0,0.12); 
      width: 100%; 
      max-width: 420px; 
      text-align: center; 
      border-top: 5px solid #1a2a4d; 
    }
    .logo { width: clamp(60px, 15vw, 90px); margin-bottom: 15px; }
    h2 { margin-bottom: 8px; font-weight: 800; color: #1a2a4d; font-size: clamp(20px, 5vw, 26px); }
    .subtitle { color: #888; font-size: clamp(11px, 2vw, 13px); margin-bottom: clamp(20px, 5vw, 30px); }
    .form-group { text-align: left; margin-bottom: 20px; }
    label { font-size: clamp(12px, 2vw, 14px); font-weight: 700; color: #1a2a4d; display: block; margin-bottom: 8px; }
    input { 
      width: 100%; padding: 14px 16px; 
      border: 2px solid #e0e0e0; border-radius: 12px; 
      box-sizing: border-box; font-size: clamp(13px, 2vw, 15px); 
    }
    input:focus { border-color: #1a2a4d; outline: none; }
    .btn-submit { 
      width: 100%; 
      background: linear-gradient(135deg, #1a2a4d 0%, #2d4a8d 100%); 
      color: white; padding: 15px; border: none; border-radius: 12px; 
      cursor: pointer; font-weight: bold; font-size: clamp(14px, 2vw, 17px); 
      margin-top: 15px; transition: all 0.3s; 
    }
    .btn-submit:hover { transform: translateY(-2px); }
    .links { margin-top: 25px; font-size: clamp(12px, 2vw, 14px); }
    .links a { text-decoration: none; color: #1a2a4d; font-weight: 600; }
    .links a:hover { color: #ff8c00; }
    .message { 
      color: #155724; font-size: clamp(11px, 2vw, 13px); margin-bottom: 15px; 
      background: #d4edda; padding: 10px 15px; border-radius: 8px; 
      border-left: 4px solid #28a745;
    }
    .error-msg { 
      color: #d9534f; font-size: clamp(11px, 2vw, 13px); margin-bottom: 15px; 
      background: #ffeaea; padding: 10px 15px; border-radius: 8px; 
      border-left: 4px solid #d9534f;
    }
  </style>
</head>
<body>
  <div class="container">
    <img src="/images/escr-logo.png" class="logo" alt="ESCR Logo" style="width: 120px;" onerror="this.src='https://via.placeholder.com/120x120?text=ESCR'">
    <h2>Reset Password</h2>
    <p class="subtitle">Enter your email to reset your password</p>

    <% if (message === 'sent') { %>
      <div class="message">Password reset link has been sent to your email!</div>
    <% } %>
    
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error-msg"><%= error %></div>
    <% } %>

    <form method="POST" action="/forgot-password">
      <div class="form-group">
        <label>Email Address</label>
        <input type="email" name="email" placeholder="Enter your email" required>
      </div>

      <button type="submit" class="btn-submit">Send Reset Link</button>
    </form>

    <div class="links">
      <a href="/login"><i class="fa fa-arrow-left"></i> Back to Login</a>
    </div>
  </div>
</body>
</html>
